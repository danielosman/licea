import fs from 'node:fs';
import path from 'node:path';

const schoolsDir = path.resolve(process.cwd(), '../schools');

function loadSchools() {
  const schools: any[] = [];
  for (const folder of fs.readdirSync(schoolsDir).sort()) {
    const jsonFile = path.join(schoolsDir, folder, `${folder}.json`);
    if (fs.existsSync(jsonFile)) {
      schools.push(JSON.parse(fs.readFileSync(jsonFile, 'utf-8')));
    }
  }
  return schools.sort((a, b) => parseInt(a.school_id) - parseInt(b.school_id));
}

const schools = loadSchools();

// ── Field labels ──────────────────────────────────────────────────────────────
const FL: Record<string, string> = {
  avg_score: 'Ocena średnia',
  synthetic_score: 'Ocena syntetyczna',
