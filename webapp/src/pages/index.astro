// ── Metric definitions ────────────────────────────────────────────────────────
const SCORED_METRICS = [
  { key: 'openness',          label: 'Otwartość',          type: 'standard',
    detailFields: ['erasmus','external_collaboration','guests','teacher_availability','current_topics','new_technologies'] },
  { key: 'friendliness',      label: 'Przyjazność',        type: 'standard',
    detailFields: ['psychologist','support_programs','mental_wellbeing','diversity_acceptance','anti_bullying','opinion_expression'] },
  { key: 'engagement',        label: 'Zaangażowanie',      type: 'standard',
    detailFields: ['clubs','unusual_activities','interest_development','volunteering','student_initiatives','student_council'] },
  { key: 'intellectual_profile', label: 'Profil intelektualny', type: 'intellectual',
    detailFields: ['class_profiles_stem','class_profiles_humanities','clubs_stem','clubs_humanities','olympiads_stem','olympiads_humanities'] },
  { key: 'worldview',         label: 'Światopogląd',       type: 'worldview',    detailFields: [] as string[] },
  { key: 'school_balance',    label: 'Równowaga szkolna',  type: 'balance',      detailFields: [] as string[] },
  { key: 'innovation',        label: 'Innowacyjność',      type: 'standard',
    detailFields: ['initiatives','extracurricular_topics'] },
  { key: 'message_coherence', label: 'Spójność przekazu',  type: 'standard',
    detailFields: ['contradictions'] },
];

const UNSCORED_METRICS = [
  { key: 'languages',     label: 'Języki',
    fields: ['english','german','spanish','other','bilingual_classes','bilingual_language','certificates','language_choice','language_choice_details','level_groups','native_speakers','notes'] },
  { key: 'classes',       label: 'Klasy',       fields: null as null | string[] },
  { key: 'infrastructure',label: 'Infrastruktura',
    fields: ['cafeteria','library','auditorium','nurse_office','specialized_labs','building_condition','notes'] },
  { key: 'sports',        label: 'Sport',
    fields: ['courts','gyms','fitness_room','pool','access_outside_lessons','sports_clubs','sports_achievements','notes'] },
];

const SURVEY_FIELDS = [
  'survey_count','matura_score_pct','matura_pass_rate_pct','atmosphere_pct',
  'learning_enjoyment_pct','student_relations_pct','student_teacher_relations_pct',
  'teaching_modernity_pct','recommendation_rate_pct','break_quality_pct',
  'avg_study_time_after_school','student_count_2022','year_founded','amenities',
];
const SL: Record<string, string> = {
  survey_count: 'Liczba ankiet',
  matura_score_pct: 'Wyniki matur (%)',
  matura_pass_rate_pct: 'Zdawalność matur (%)',
  atmosphere_pct: 'Atmosfera (%)',
  learning_enjoyment_pct: 'Przyjemność z nauki (%)',
  student_relations_pct: 'Relacje między uczniami (%)',
  student_teacher_relations_pct: 'Relacje uczeń–nauczyciel (%)',
  teaching_modernity_pct: 'Nowoczesność nauczania (%)',
  recommendation_rate_pct: 'Polecałbym/łabym (%)',
  break_quality_pct: 'Jakość przerw (%)',
  avg_study_time_after_school: 'Czas nauki po szkole',
  student_count_2022: 'Liczba uczniów (2022)',
  year_founded: 'Rok założenia',
  amenities: 'Udogodnienia',
};

// ── Value rendering ───────────────────────────────────────────────────────────
function esc(s: unknown): string {
  return String(s ?? '')
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

function renderValue(val: unknown): string {
  if (val === null || val === undefined || val === '') return '—';
  if (typeof val === 'boolean') return val ? 'tak' : 'nie';
  if (Array.isArray(val)) {
    if (val.length === 0) return '—';
    if (typeof val[0] === 'object' && val[0] !== null && 'letter' in (val[0] as object)) {
      return (val as any[]).map(cls =>
        `<div class="class-item">` +
        `<strong>${esc(cls.letter)}</strong>${cls.name ? ` — ${esc(cls.name)}` : ''}` +
        (cls.extended_subjects?.length ? `<br><span class="muted">Rozszerzenia: ${cls.extended_subjects.map(esc).join(', ')}</span>` : '') +
        (cls.notes ? `<br><span class="muted">${esc(cls.notes)}</span>` : '') +
        `</div>`
      ).join('');
    }
    if (val.length <= 3) return val.map(v => esc(String(v))).join(', ');
    return `<ul>${val.map(v => `<li>${esc(String(v))}</li>`).join('')}</ul>`;
  }
  return esc(String(val));
}

// ── Score rendering (for a single school's cell) ──────────────────────────────
function synthScoreHtml(metric: any, type: string): string {
  if (!metric) return '<span class="dash">—</span>';
  switch (type) {
    case 'intellectual':
      return `<div class="score-pair">` +
        `<div><div class="score-sub-label">Humanistyczny</div><div class="score">${metric.humanities?.synthetic_score ?? '—'}</div></div>` +
        `<div><div class="score-sub-label">Ścisły</div><div class="score">${metric.stem?.synthetic_score ?? '—'}</div></div>` +
        `</div>`;
    case 'worldview':
      return `<div class="score-pair">` +
        `<div><div class="score-sub-label">Lewicowy</div><div class="score">${metric.left_synthetic_score ?? '—'}</div></div>` +
        `<div><div class="score-sub-label">Prawicowy</div><div class="score">${metric.right_synthetic_score ?? '—'}</div></div>` +
        `</div>`;
    case 'balance':
      return `<div class="score-pair">` +
        `<div><div class="score-sub-label">Nauka</div><div class="score">${metric.academics_synthetic_score ?? '—'}</div></div>` +
        `<div><div class="score-sub-label">Pasje</div><div class="score">${metric.hobbies_synthetic_score ?? '—'}</div></div>` +
        `</div>`;
    default:
      return `<div class="score">${metric.synthetic_score ?? '—'}</div>`;
  }
}

function avgScoreHtml(metric: any, type: string): string {
  if (!metric) return '';
  switch (type) {
    case 'intellectual':
      return fieldHtml('avg_score', metric.humanities?.avg_score, 'Humanistyczny (średnia)') +
             fieldHtml('avg_score', metric.stem?.avg_score, 'Ścisły (średnia)');
    case 'worldview':
      return fieldHtml('left_avg_score', metric.left_avg_score) +
             fieldHtml('right_avg_score', metric.right_avg_score);
    case 'balance':
      return fieldHtml('academics_avg_score', metric.academics_avg_score) +
             fieldHtml('hobbies_avg_score', metric.hobbies_avg_score);
    default:
      return fieldHtml('avg_score', metric.avg_score);
  }
}

function fieldHtml(key: string, val: unknown, labelOverride?: string): string {
  if (val === null || val === undefined) return '';
  const label = labelOverride ?? FL[key] ?? key;
  return `<div class="field"><div class="field-label">${esc(label)}</div><div class="field-value">${renderValue(val)}</div></div>`;
}

// ── Helpers ───────────────────────────────────────────────────────────────────
function anyHas(fieldPath: string, metricKey: string): boolean {
  return schools.some(s => {
    const m = s.metrics?.[metricKey];
    return m != null && m[fieldPath] != null;
  });
}
